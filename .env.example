# Robinhood Chain RPC — server-side only (defaults to the public mainnet RPC).
RHC_RPC_URL=https://rpc.mainnet.chain.robinhood.com

# ---- Visible unique-visitor + fight counter (OPTIONAL) ----
# Provision an Upstash Redis (or Vercel KV) and set these to light up the on-page
# counter. Without them the counter simply hides; Vercel Web Analytics still works.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
